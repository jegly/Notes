    <string name="terms_changes_title">8. Zmeny podmienok</string>
    <string name="terms_contact_body">V prípade akýchkoľvek otázok týkajúcich sa týchto podmienok poskytovania služieb alebo poznámok Notes nás kontaktujte na adrese</string>
