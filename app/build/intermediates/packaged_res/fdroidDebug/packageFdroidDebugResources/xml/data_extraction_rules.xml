<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ data-extraction rules.
    Cloud backup and device-to-device transfer are both fully disabled for
    Notes because the database, DataStore preferences (which contain the
    passcode/pattern hashes and vault password) and note images must never
    leave the device via Google's backup infrastructure.

    Users who want a backup should use the in-app encrypted export feature.
-->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <!-- Block the notes database -->
        <exclude domain="database" path="." />
        <!-- Block DataStore preferences (contains credential hashes) -->
        <exclude domain="file" path="datastore" />
        <!-- Block note attachment images -->
        <exclude domain="file" path="images" />
        <!-- Block all shared preferences as a catch-all -->
        <exclude domain="sharedpref" path="." />
    </cloud-backup>

    <device-transfer>
        <exclude domain="database" path="." />
        <exclude domain="file" path="datastore" />
        <exclude domain="file" path="images" />
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
